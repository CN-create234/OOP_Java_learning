### 7.3 格式化内存输入（DataInputStream + ByteArrayInputStream）

```java
import java.io.*;

public class FormattedMemoryInput {
    public static void main(String[] args) throws IOException {
        try {
            DataInputStream in = new DataInputStream(
                new ByteArrayInputStream(
                    BufferedInputStream.read("FormattedMemoryInput.java").getBytes()
                )
            );
            while (true) {
                System.out.print((char) in.readByte());
            }
        } catch (EOFException e) {
            System.err.println("End of stream");
        }
    }
}
```

### 7.4 检测文件结束（available()）

```java
import java.io.*;

public class TestEOF {
    public static void main(String[] args) throws IOException {
        DataInputStream in = new DataInputStream(
            new BufferedInputStream(
                new FileInputStream("TestEOF.java")
            )
        );
        
        while (in.available() != 0) {
            System.out.print((char) in.readByte());
        }
    }
}
```

### 7.5 文件输出（PrintWriter）

```java
import java.io.*;

public class BasicFileOutput {
    static String file = "BasicFileOutput.out";
    
    public static void main(String[] args) throws IOException {
        BufferedReader in = new BufferedReader(
            new StringReader(
                BufferedReaderFile.read("BasicFileOutput.java")
            )
        );
        
        PrintWriter out = new PrintWriter(
            new BufferedWriter(new FileWriter(file))
        );
        
        int lineCount = 1;
        String s;
        while ((s = in.readLine()) != null) {
            out.println(lineCount++ + ":" + s);
        }
        out.close();
        
        // 显示存储的文件
        System.out.println(BufferedReaderFile.read(file));
    }
}
```

### 7.6 存储和恢复数据（DataOutputStream / DataInputStream）

```java
import java.io.*;

public class StoringAndRecoveringData {
    public static void main(String[] args) throws IOException {
        // 写入数据
        DataOutputStream out = new DataOutputStream(
            new BufferedOutputStream(new FileOutputStream("Data.txt"))
        );
        out.writeDouble(3.14159);
        out.writeUTF("That was pi");
        out.writeDouble(1.41413);
        out.writeUTF("Square root of 2");
        out.close();
        
        // 读取数据（必须按写入顺序读取）
        DataInputStream in = new DataInputStream(
            new BufferedInputStream(new FileInputStream("Data.txt"))
        );
        System.out.println(in.readDouble());
        System.out.println(in.readUTF());
        System.out.println(in.readDouble());
        System.out.println(in.readUTF());
    }
}
```

### 7.7 标准 I/O

```java
public class Echo {
    public static void main(String[] args) throws IOException {
        BufferedReader stdin = new BufferedReader(
            new InputStreamReader(System.in)
        );
        
        String s;
        while ((s = stdin.readLine()) != null && s.length() != 0) {
            System.out.println(s);
        }
    }
}
```

